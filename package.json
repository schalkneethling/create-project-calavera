{
  "name": "create-project-calavera",
  "version": "1.0.0",
  "description": "Compose and apply modern tooling recipes for JavaScript and TypeScript projects.",
  "keywords": [
    "cli",
    "css",
    "html",
    "javascript",
    "linting",
    "oxlint",
    "prettier",
    "project",
    "scaffold",
    "starter",
    "stylelint",
    "tooling"
  ],
  "homepage": "https://github.com/schalkneethling/create-project-calavera#readme",
  "bugs": {
    "url": "https://github.com/schalkneethling/create-project-calavera/issues"
  },
  "license": "MIT",
  "author": "Schalk Neethling",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/schalkneethling/create-project-calavera.git"
  },
  "bin": {
    "create-project-calavera": "src/index.js"
  },
  "files": [
    "src",
    "LICENSE",
    "README.md"
  ],
  "type": "module",
  "exports": "./src/index.js",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "prettier:lint": "prettier .",
    "prettier:format": "prettier --write .",
    "lint:js": "eslint .",
    "lint:css": "stylelint **/*.css",
    "web:dev": "vite --host 127.0.0.1",
    "web:build": "vite build",
    "web:preview": "vite preview --host 127.0.0.1",
    "check": "pnpm lint && pnpm format:check && pnpm typecheck",
    "lint": "node .calavera/run-if-files.mjs \"JavaScript/TypeScript\" \"js,jsx,ts,tsx,mjs,cjs\" -- oxlint . && node .calavera/run-if-files.mjs \"CSS\" \"css,scss\" -- stylelint \"**/*.{css,scss}\"",
    "lint:fix": "node .calavera/run-if-files.mjs \"JavaScript/TypeScript\" \"js,jsx,ts,tsx,mjs,cjs\" -- oxlint --fix . && node .calavera/run-if-files.mjs \"CSS\" \"css,scss\" -- stylelint \"**/*.{css,scss}\" --fix",
    "format": "node .calavera/run-if-files.mjs \"JavaScript/TypeScript\" \"js,jsx,ts,tsx,mjs,cjs\" -- oxfmt --write .",
    "format:check": "node .calavera/run-if-files.mjs \"JavaScript/TypeScript\" \"js,jsx,ts,tsx,mjs,cjs\" -- oxfmt --check .",
    "typecheck": "node .calavera/run-if-files.mjs \"TypeScript\" \"ts,tsx\" -- tsc --noEmit",
    "publish:check": "publint",
    "workflow:check": "uvx zizmor@1.25.2 --offline .github/workflows"
  },
  "dependencies": {
    "@clack/prompts": "^0.11.0",
    "chalk": "^5.3.0",
    "execa": "^9.6.0",
    "prettier": "^3.5.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@schalkneethling/stylelint-plugin-css-property-type-validator": "0.1.0-beta.1",
    "eslint": "^10.4.0",
    "globals": "^16.2.0",
    "oxfmt": "^0.52.0",
    "oxlint": "^1.67.0",
    "publint": "^0.3.21",
    "stylelint": "^17.12.0",
    "stylelint-config-standard": "^38.0.0",
    "stylelint-order": "^7.0.1",
    "stylelint-plugin-use-baseline": "^1.4.2",
    "typescript": "^6.0.3",
    "vite": "^8.0.14"
  },
  "packageManager": "pnpm@11.3.0"
}
